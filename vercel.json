{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "bird-feeder-platform/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://43.255.31.97/api/:path*"
    },
    {
      "source": "/upload",
      "destination": "http://43.255.31.97/upload"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://43.255.31.97/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
