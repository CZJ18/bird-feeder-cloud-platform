# MySQL on Oracle Ubuntu
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=birdcam_user
DB_PASSWORD=change_me
DB_NAME=birdcam_db

# Teacher MQTT broker
MQTT_HOST=teacher-broker.example.com
MQTT_PORT=8883
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_pass
MQTT_TLS_CA_PATH=/opt/birdcam/backend/certs/mqtt_ca.crt
MQTT_TOPIC_EVENT=birdcam/event
MQTT_TOPIC_STATUS=birdcam/status
MQTT_RECONNECT_INTERVAL_SECONDS=5
AUTO_CREATE_DEVICE_FROM_MQTT=true

# Local file storage on Oracle server
UPLOAD_BASE_DIR=/opt/birdcam/backend/uploads/low_confidence
UPLOAD_PUBLIC_PREFIX=/uploads/low_confidence
MAX_UPLOAD_SIZE_MB=10

# API security
DASHBOARD_API_TOKEN=change_me_to_a_long_random_token
DEVICE_API_KEY_LENGTH=64

# Device status
DEVICE_ONLINE_SECONDS=300

# FastAPI service
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Keep FastAPI and MQTT worker separated in production.
# FastAPI service: ENABLE_MQTT=false
# MQTT worker service: python -m app.worker
ENABLE_MQTT=false

# Vercel frontend domain and local dev domains
CORS_ORIGINS=https://bird-feeder-cloud-platform.vercel.app,http://localhost:5173,http://127.0.0.1:5173
